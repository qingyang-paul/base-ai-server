# ====================================
# Base Infra: Database & logger Config
# ====================================

# Logger
LOG_JSON_FORMAT=true

# Telemetry
OTEL_SERVICE_NAME=base-ai-server
OTEL_EXPORTER_ENDPOINT=http://localhost:4317
OTEL_INSECURE=true

# Environment
WORK_ENVIRONMENT=development

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_MAX_CONNECTIONS=10

# Postgres
PG_HOST=localhost
PG_PORT=5432
PG_DATABASE=base_ai_server
PG_USER=dev
PG_PASSWORD=dev
PG_MIN_POOL_SIZE=2
PG_MAX_POOL_SIZE=10

# ====================================
# Chat Service: LLM Runtime Config
# ====================================

# LLM - OpenAI
OPENAI__API_KEY=sk-proj-...
OPENAI__MODEL=gpt-4-turbo
OPENAI__TEMPERATURE=0.7
OPENAI__MAX_TOKENS=2048

# LLM - Gemini
GEMINI__API_KEY=AIza...
GEMINI__MODEL=gemini-1.5-pro
GEMINI__TEMPERATURE=1.0
GEMINI__MAX_OUTPUT_TOKENS=8192
GEMINI__TOP_K=40

# LLM - Qwen (Optional)
QWEN__API_KEY=sk-...
QWEN__BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN__MODEL=qwen-max
QWEN__TEMPERATURE=1.0
QWEN__MAX_OUTPUT_TOKENS=8192
QWEN__TOP_K=40
